@{
    Layout = null;
    ViewData["Title"] = "Add Candidate";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] - Online Election System</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha3/dist/css/bootstrap.min.css">

    <style>
        body {
            background: linear-gradient(to bottom right, #6a11cb, #2575fc);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .card-container {
            background: #ffffff;
            border-radius: 15px;
            padding: 30px;
            width: 600px;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
        }

        h3 {
            color: dimgrey;
        }

        .form-label {
            font-weight: bold;
            color: #343a40;
        }

        .btn-custom {
            background: linear-gradient(to right, #6a11cb, #2575fc);
            color: #fff;
            border: none;
            font-weight: bold;
            transition: all 0.3s ease-in-out;
        }

        .btn-custom:hover {
            background: linear-gradient(to right, #2575fc, #6a11cb);
            transform: scale(1.03);
        }

        .form-control:focus {
            border-color: #6a11cb;
            box-shadow: 0 0 5px rgba(106, 17, 203, 0.5);
        }
    </style>
</head>

<body>

    <div class="card-container">
        <h3 class="text-center fw-bolder mb-3">@ViewData["Title"]</h3>

        <form asp-action="AddCandidate" asp-controller="Candidate" method="post" enctype="multipart/form-data">
             <!-- ADD THIS -->
            <input type="hidden" name="ElectionId" value="@ViewBag.ElectionId" />

            <div class="mb-3">
                <label for="name" class="form-label">Name</label>
                <input type="text" id="name" name="name" class="form-control" required />
            </div>

            <div class="mb-3">
                <label for="age" class="form-label">Age</label>
                <input type="number" id="age" name="age" class="form-control" min="18" required />
            </div>

            <div class="mb-3">
                <label for="citno" class="form-label">Citizenship Number</label>
                <input type="text" id="citno" name="citno" class="form-control" required />
            </div>

            <div class="mb-3">
                <label for="edu" class="form-label">Education</label>
                <input type="text" id="edu" name="edu" class="form-control" required />
            </div>

            <div class="mb-3">
                <label for="party" class="form-label">Political Party</label>
                <input type="text" id="party" name="party" class="form-control" required />
            </div>

            <div class="mb-3">
                <label for="profile" class="form-label">Profile Picture</label>
                <input type="file" id="profile" name="profile" class="form-control" accept="image/*" required />
            </div>

            <div class="mb-3">
                <label for="logo" class="form-label">Party Logo</label>
                <input type="file" id="logo" name="logo" class="form-control" accept="image/*" required />
            </div>

            <div class="mb-3">
                <label for="manifesto" class="form-label">Manifesto</label>
                <textarea id="manifesto" name="manifesto" class="form-control" rows="4" required></textarea>
            </div>

            <div class="d-grid">
                <button type="submit" class="btn btn-custom">Add Candidate</button>
            </div>

        </form>

        <!-- Validation Errors -->
        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-danger mt-3">
                <ul class="mb-0">
                    @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                    {
                        <li>@error.ErrorMessage</li>
                    }
                </ul>
            </div>
        }

        <!-- Back Button -->
        <div class="text-center mt-3">
            <a asp-controller="Admin" asp-action="Index" class="btn btn-custom">← Back to Dashboard</a>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha3/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>