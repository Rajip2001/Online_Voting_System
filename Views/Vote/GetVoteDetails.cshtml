@{
    Layout = null;
}

@model OnlineVoting.Models.ViewModels.VoteDetailsViewModel

<!DOCTYPE html>
<html>
<head>
    <title>Vote Details</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            background: linear-gradient(to bottom right, #6a11cb, #2575fc);
            height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            margin: 0;
        }

        .container {
            max-width: 600px;
            width: 100%;
            background-color: white;
            padding: 20px;
            border-radius: 8px;
            box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);
            text-align: center;
        }

        h1 {
            color: #007BFF; /* Blue title */
            margin-bottom: 20px;
        }

        .details {
            display: flex;
            flex-direction: column;
            gap: 15px;
            text-align: left;
        }

            .details div {
                display: flex;
                justify-content: space-between;
                font-size: 16px;
            }

                .details div span {
                    font-weight: bold;
                    color: #343a40;
                }

            .details img {
                max-width: 150px;
                border-radius: 50%;
                margin-top: 10px;
            }

        .btn-secondary {
            background-color: #f8f9fa; /* Light grey background */
            color: #007BFF; /* Blue text */
            border: 2px solid #007BFF; /* Blue border */
            font-weight: bold;
            padding: 10px 20px;
            margin-top: 20px;
            border-radius: 5px;
            display: inline-block;
            text-align: center;
            text-decoration: none;
        }

            .btn-secondary:hover {
                background-color: #e2e6ea;
                color: #0056b3; /* Darker blue text */
            }
    </style>
</head>
<body>

    <div class="container">
        <h1 class="fw-bolder">Vote Details</h1>

        <div class="details">
            <div>
                <span>Election Name:</span>
                <span>@Model.ElectionName</span>
            </div>
            <div>
                <span>Candidate Name:</span>
                <span>@Model.CandidateName</span>
            </div>
            <div>
                <span>Voter Name:</span>
                <span>@Model.VoterName</span>
            </div>
            <div>
                <span>Voter Email:</span>
                <span>@Model.VoterEmail</span>
            </div>
            <div>
                <span>Cast Date & Time:</span>
                <span>@Model.CastDateTime.ToString("MM/dd/yyyy hh:mm tt")</span>
            </div>
            <div>
                <img src="@Model.CandidatePhotoUrl" alt="Candidate Photo">
            </div>
        </div>

        <a href="@Url.Action("Index", "Vote")" class="btn-secondary">Back to Voting</a>
    </div>

</body>
</html>
