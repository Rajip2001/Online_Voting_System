@model IList<OnlineVoting.Models.Candidate>

@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <title>Cast Your Vote</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">

    <style>
        body {
            background: linear-gradient(to bottom right, #6a11cb, #2575fc);
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
        }

        .container-box {
            background: white;
            padding: 25px;
            border-radius: 12px;
            width: 800px;
            box-shadow: 0 4px 20px rgba(0,0,0,0.1);
        }

        .candidate-card {
            border: 1px solid #ddd;
            border-radius: 10px;
            padding: 15px;
            margin-bottom: 15px;
        }

        img {
            width: 80px;
            height: 80px;
            object-fit: cover;
            border-radius: 8px;
        }

        .btn-vote {
            background: linear-gradient(to right, #6a11cb, #2575fc);
            color: white;
            border: none;
        }

        .btn-vote:hover {
            transform: scale(1.05);
        }
    </style>
</head>

<body>

<div class="container-box">

    <h3 class="text-center fw-bold mb-4">Vote for Your Candidate</h3>

    @if (Model != null && Model.Any())
    {
        <form method="post" asp-controller="Vote" asp-action="CastVote">

            @foreach (var candidate in Model)
            {
                <div class="candidate-card">

                    <div class="row align-items-center">

                        <!-- Profile Image -->
                        <div class="col-md-2">
                            @if (!string.IsNullOrEmpty(candidate.ProfilePicture))
                            {
                                <img src="@candidate.ProfilePicture" />
                            }
                            else
                            {
                                <p>No Image</p>
                            }
                        </div>

                        <!-- Details -->
                        <div class="col-md-7">
                            <h5>@candidate.Name</h5>
                            <p><strong>Age:</strong> @candidate.Age</p>
                            <p><strong>Education:</strong> @candidate.Education</p>
                            <p><strong>Party:</strong> @candidate.Party</p>
                            <p><strong>Manifesto:</strong> @candidate.Manifesto</p>
                        </div>

                        <!-- Logo + Vote -->
                        <div class="col-md-3 text-center">
                            @if (!string.IsNullOrEmpty(candidate.Logo))
                            {
                                <img src="@candidate.Logo" />
                            }

                            <br /><br />

                            <button type="submit"
                                    name="candidateId"
                                    value="@candidate.CandidateId"
                                    class="btn btn-vote">
                                Vote
                            </button>
                        </div>

                    </div>

                </div>
            }

        </form>
    }
    else
    {
        <p class="text-danger text-center">No candidates available.</p>
    }

</div>

</body>
</html>