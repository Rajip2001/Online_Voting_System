@model OnlineVoting.Models.Election

@{
    ViewData["Title"] = "Delete Election";
}

<h1>Delete Election</h1>

<p>Are you sure you want to delete the election <strong>@Model.Name</strong>?</p>

<form asp-action="DeleteElection" method="post">
    <input type="hidden" name="ElectionId" value="@Model.ElectionId" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>

