@{
    Layout = null;
    ViewData["Title"] = "Admin Dashboard";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] - Online Election System</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha3/dist/css/bootstrap.min.css">

    <style>
        body {
            background: linear-gradient(to bottom right, #6a11cb, #2575fc);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .dashboard-card {
            background: #ffffff;
            border: none;
            width: 500px;
            border-radius: 15px;
            padding: 30px;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
        }

        .section-title {
            color: #343a40;
            font-weight: bold;
            margin-top: 15px;
            margin-bottom: 10px;
        }

        .btn-custom {
            background: linear-gradient(to right, #6a11cb, #2575fc);
            color: #fff;
            border: none;
            font-weight: bold;
            transition: all 0.3s ease-in-out;
        }

        .btn-custom:hover {
            background: linear-gradient(to right, #2575fc, #6a11cb);
            transform: scale(1.05);
        }

        h3 {
            color: dimgrey;
        }
    </style>
</head>

<body>

    <div class="dashboard-card">
        <h3 class="text-center fw-bolder">@ViewData["Title"]</h3>

        <!-- Elections -->
        <div>
            <div class="section-title">Manage Elections</div>
            <div class="d-grid gap-2">
                <a asp-controller="Election" asp-action="ScheduleElection" class="btn btn-custom">Create Election</a>
                <a asp-controller="Election" asp-action="GetAllElections" class="btn btn-custom">View Elections</a>
            </div>
        </div>

        <!-- Candidates -->
        <div>
            <div class="section-title">Manage Candidates</div>
            <div class="d-grid gap-2">
                <a asp-controller="Candidate" asp-action="AddCandidate" class="btn btn-custom">Register Candidate</a>
                <a asp-controller="Election" asp-action="ViewCandidates" class="btn btn-custom">View Candidates</a>
            </div>
        </div>

        <!-- Voters -->
        <div>
            <div class="section-title">Manage Voters</div>
            <div class="d-grid gap-2">
                <a asp-controller="Admin" asp-action="GetVoterList" class="btn btn-custom">View Voters</a>
            </div>
        </div>

        <!-- Results -->
        @* <div>
            <div class="section-title">Results</div>
            <div class="d-grid gap-2">
                <a asp-controller="Admin" asp-action="ElectionResult" class="btn btn-custom">View Results</a>
            </div>
        </div> *@

    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha3/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>