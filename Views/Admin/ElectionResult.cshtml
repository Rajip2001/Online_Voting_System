
@{
    Layout = null;
}
@model OnlineVoting.Models.ViewModels.ResultViewModel

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Election Results - @Model.ElectionDetails.Name</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha3/dist/css/bootstrap.min.css">

    <style>
        body {
            background: linear-gradient(to bottom right, #6a11cb, #2575fc);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .result-card {
            background: #ffffff;
            border: none;
            width: 800px;
            border-radius: 15px;
            padding: 30px;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
        }

        .table th {
            background: linear-gradient(to right, #6a11cb, #2575fc);
            color: white;
        }
    </style>
</head>

<body>

    <div class="result-card">

        <!-- Title inside box (same as dashboard) -->
        <h3 class="text-center fw-bolder" style="color:dimgrey;">
            Election Results for @Model.ElectionDetails.Name
        </h3>

        <hr />

        <p><strong>Status:</strong> @Model.ElectionDetails.Status</p>

        <p>
            <strong>Election Period:</strong>
            @Model.ElectionDetails.StartDate.ToShortDateString()
            -
            @Model.ElectionDetails.EndDate.ToShortDateString()
        </p>

        <p><strong>Total Votes Cast:</strong> @Model.TotalVotes</p>

        <p><strong>Voter Turnout:</strong> @Model.TurnoutPercentage.ToString("F2")%</p>

        <hr />

        <h5 class="fw-bold">Winner</h5>

        @if (Model.Winner != null)
        {
            <p>
                <strong>@Model.Winner.Name</strong> from the
                <strong>@Model.Winner.Party</strong> party won with
                <strong>@Model.Winner.VoteCount</strong> votes.
            </p>
        }
        else
        {
            <p>No winner yet. Election is ongoing or no votes have been cast.</p>
        }

        <hr />

        <h5 class="fw-bold">All Candidates</h5>

        <table class="table table-bordered table-striped mt-3">
            <thead>
                <tr>
                    <th>Candidate Name</th>
                    <th>Party</th>
                    <th>Votes</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var candidate in Model.ElectionDetails.Candidates)
                {
                    <tr>
                        <td>@candidate.Name</td>
                        <td>@candidate.Party</td>
                        <td>@candidate.VoteCount</td>
                    </tr>
                }
            </tbody>
        </table>

        <div class="text-center mt-3">
            <button class="btn btn-primary" onclick="location.reload()">
                Refresh Results
            </button>
        </div>
                <div class="text-center mt-3">
            <a asp-controller="Admin" asp-action="Index" class="btn btn-primary">
                ← Back to Dashboard
            </a>
            </div>
    </div>

</body>
</html>
