@model OnlineVoting.Models.User

@{
    Layout = null;
    ViewData["Title"] = "REGISTER";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] - Online Election System</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha3/dist/css/bootstrap.min.css">
    <style>
        body {
            background: linear-gradient(to bottom right, #6a11cb, #2575fc); /* Gradient background */
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .card {
            margin: 100px;
            background: #ffffff; /* Clean white card */
            border: none;
            width: 500px;
            border-radius: 15px;
            padding: 30px;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1); /* Subtle shadow */
        }

        .btn-custom {
            background: linear-gradient(to right, #6a11cb, #2575fc); /* Gradient button */
            color: #fff;
            border: none;
            font-weight: bold;
            transition: all 0.3s ease-in-out;
        }

            .btn-custom:hover {
                background: linear-gradient(to right, #2575fc, #6a11cb);
                transform: scale(1.05); /* Subtle hover animation */
            }

        h3 {
            color: #343a40;
            margin-bottom: 20px;
            text-align: center;
        }
    </style>
</head>
<body>
    <div class="card">
        <h3 style="color:dimgrey" class="fw-bolder">@ViewData["Title"]</h3>
        @if (ViewData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger text-center">@ViewData["ErrorMessage"]</div>
        }

        <form asp-action="InsertUser" method="post">
            <div class="mb-3">
                <label style="color:dimgray" for="Name" class="form-label fw-bolder">Name*</label>
                <input type="text" class="form-control" id="Name" name="Name" placeholder="Enter full name" required />
            </div>
            <div class="mb-3">
                <label style="color:dimgray" for="Email" class="form-label fw-bolder">Email*</label>
                <input type="email" class="form-control" id="Email" name="Email" placeholder="Enter your email" required />
            </div>
            <div class="mb-3">
                <label style="color:dimgray" for="Password" class="form-label fw-bolder">Password*</label>
                <input type="password" class="form-control" id="Password" name="Password" placeholder="Enter a password" required />
            </div>
            <div class="mb-3">
                <label style="color:dimgray" for="CITNo" class="form-label fw-bolder">CITNo*</label>
                <input type="text" class="form-control" id="CITNo" name="CITNo" placeholder="CITNo" required />
            </div>
            <div class="mb-3">
                <label style="color:dimgray" for="DOB" class="form-label fw-bolder">Date of Birth*</label>
                <input type="date" class="form-control" id="DOB" name="DOB" required />
            </div>
            <div class="mb-3">
                <label style="color:dimgray" for="Role" class="form-label fw-bolder">Role*</label>
                <select class="form-control" id="Role" name="Role" required>
                    <option value="">Select Role</option>
                    <option value="Voter">Voter</option>
                    <option value="Admin">Administrator</option>
                </select>
            </div>

            <div class="d-grid">
                <button type="submit" class="btn btn-custom">Sign up</button>
            </div>
        </form>
        <div class="text-center mt-3">
            <small>Already have an account? <a asp-action="Login" class="text-decoration-none">Login here</a></small>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
