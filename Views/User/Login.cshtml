@model OnlineVoting.Models.User

@{
    Layout = null;
    ViewData["Title"] = "Login";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] - Online Election System</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha3/dist/css/bootstrap.min.css">
    <style>
        body {
            background: linear-gradient(to bottom right, #6a11cb, #2575fc); /* Gradient background */
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .header {
            background-color: rgba(0, 0, 0, 0.7); /* Transparent dark overlay */
            color: #fff;
            padding: 10px;
            text-align: center;
            border-radius: 8px;
            margin-bottom: 20px;
        }

        .card {
            background: #ffffff; /* Clean white card */
            border: none;
            width: 350px;
            border-radius: 15px;
            padding: 30px;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1); /* Subtle shadow */
        }

        .btn-custom {
            background: linear-gradient(to right, #6a11cb, #2575fc); /* Gradient button */
            color: #fff;
            border: none;
            font-weight: bold;
            transition: all 0.3s ease-in-out;
        }

            .btn-custom:hover {
                background: linear-gradient(to right, #2575fc, #6a11cb);
                transform: scale(1.05); /* Subtle hover animation */
            }

        a.text-decoration-none {
            color: #2575fc; /* Link color */
        }

            a.text-decoration-none:hover {
                text-decoration: underline; /* Hover effect for links */
            }

        h3 {
            color: #343a40;
        }
    </style>
</head>
<body>



    <div class="card">
        <h3 style="color:dimgrey" class="text-center fw-bolder">@ViewData["Title"]</h3>
        @if (TempData["error"] != null)
        {
            <div class="alert alert-danger text-center">@TempData["error"]</div>
        }

        <form asp-action="Login" method="post">
            <div class="mb-3">
                <label style="color:dimgrey" for="Email" class="form-label fw-bolder">Email*</label>
                <input type="email" class="form-control" id="Email" name="email" placeholder="Enter your email" required />
            </div>
            <div class="mb-3">
                <label style="color:dimgrey" for="Password" class="form-label fw-bolder">Password*</label>
                <input type="password" class="form-control" id="Password" name="password" placeholder="Enter your password" required />
            </div>
            <div class="d-grid">
                <button type="submit" class="btn btn-custom">Login</button>
            </div>
        </form>

        <div class="text-center mt-3">
            <small>Don't have an account? <a asp-action="InsertUser" class="text-decoration-none">Register here</a></small>
        </div>
    </div>


    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
