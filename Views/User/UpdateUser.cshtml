@{
    Layout = null;
}
@model OnlineVoting.Models.User

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Update User</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha3/dist/css/bootstrap.min.css">
    <style>
        body {
            background: linear-gradient(to bottom right, #6a11cb, #2575fc); /* Gradient background */
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
        }

        .card {
            background: #ffffff;
            margin: 100px;
            border-radius: 15px;
            padding: 30px;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1); /* Subtle shadow */
            width: 60%;
            max-width: 800px;
        }

        h1 {
            color: #343a40;
            margin-bottom: 20px;
            text-align: center;
        }

        h2 {
            color: #343a40;
            margin-top: 20px;
            text-align: center;
        }

        .btn-custom {
            background: linear-gradient(to right, #6a11cb, #2575fc);
            color: #fff;
            border: none;
            font-weight: bold;
            transition: all 0.3s ease-in-out;
            padding: 10px 20px;
            border-radius: 5px;
            display: inline-block;
            margin-top: 10px;
        }

            .btn-custom:hover {
                background: linear-gradient(to right, #2575fc, #6a11cb);
                transform: scale(1.05); /* Subtle hover animation */
            }

        a.btn-secondary {
            background-color: #f8f9fa;
            color: #6c757d;
            border: none;
            font-weight: bold;
            padding: 10px 20px;
            margin-top: 10px;
            border-radius: 5px;
        }

            a.btn-secondary:hover {
                background-color: #e2e6ea;
            }

        .alert-danger {
            color: #721c24;
            background-color: #f8d7da;
            border-color: #f5c6cb;
            padding: 15px;
            margin-top: 20px;
        }
    </style>
</head>
<body>
    <div class="card">
        <div style="display:flex; justify-content:center">
            <h3 class="fw-bolder" style="color:dimgray">Update User</h3>
        </div>
        <form method="post" asp-action="UpdateUser" id="searchForm">
            <div class="form-group">
                <label style="color:dimgray" class="fw-bolder" for="UserId">Enter User ID:</label>
                <input type="number" id="UserId" name="UserId" required class="form-control" />
            </div>
            <button type="submit" class="btn btn-custom">Search</button>
        </form>

        @if (Model != null)
        {
            <div style="display:flex; justify-content:center">
                <h3 style="color:dimgray" class="fw-bolder mt-2">User Details</h3>
            </div>
            <form method="post" asp-action="UpdateUser">
                <input type="hidden" name="UserId" value="@Model.UserId" />

                <div class="form-group">
                    <label style="color:dimgray" class="fw-bolder" for="Name">Name*</label>
                    <input type="text" class="form-control" id="Name" name="Name" value="@Model.Name" required />
                </div>

                <div class="form-group">
                    <label style="color:dimgray" class="fw-bolder" for="Email">Email*</label>
                    <input type="email" class="form-control" id="Email" name="Email" value="@Model.Email" required />
                </div>

                <div class="form-group">
                    <label style="color:dimgray" class="fw-bolder" for="Password">Password*</label>
                    <input type="password" class="form-control" id="Password" name="Password" value="@Model.Password" required />
                </div>

                <div class="form-group">
                    <label style="color:dimgray" class="fw-bolder" for="CNIC">CNIC*</label>
                    <input type="text" class="form-control" id="CNIC" name="CNIC" value="@Model.CITNo" required />
                </div>

                <div class="form-group">
                    <label style="color:dimgray" class="fw-bolder" for="DOB">Date of Birth*</label>
                    <input type="date" class="form-control" id="DOB" name="DOB" value="@Model.DOB.ToString("yyyy-MM-dd")" required />
                </div>

                <div class="form-group">
                    <label style="color:dimgray" class="fw-bolder" for="Role">Role</label>
                    <select class="form-control" id="Role" name="Role" required>
                        <option value="">Select Role</option>
                        <option value="Voter">Voter</option>
                        <option value="Admin">Administrator</option>
                    </select>
                </div>

                <button type="submit" class="btn btn-custom">Update User</button>
                <a asp-action="UserList" class="btn btn-secondary">Cancel</a>
            </form>

            @if (ViewData["ErrorMessage"] != null)
            {
                <div class="alert alert-danger">@ViewData["ErrorMessage"]</div>
            }
        }
        else if (ViewData["Message"] != null)
        {
            <p style="color: red;">@ViewData["Message"]</p>
        }
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
