@model IEnumerable<OnlineVoting.Models.User>

@{
    ViewBag.Title = "User List";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha3/dist/css/bootstrap.min.css">
    <style>
        body {
            background: linear-gradient(to bottom right, #6a11cb, #2575fc); /* Gradient background */
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: flex-start;
        }

        .container {
            margin-top: 50px;
            background-color: #fff;
            padding: 20px;
            border-radius: 15px;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
            width: 90%;
            max-width: 1000px;
        }

        .btn-custom {
            background: linear-gradient(to right, #6a11cb, #2575fc);
            color: #fff;
            border: none;
            font-weight: bold;
            padding: 10px 20px;
            border-radius: 5px;
            display: inline-block;
            margin-top: 10px;
        }

            .btn-custom:hover {
                background: linear-gradient(to right, #2575fc, #6a11cb);
                transform: scale(1.05); /* Subtle hover animation */
            }

        .table th, .table td {
            vertical-align: middle;
        }

        .table-bordered {
            border: 1px solid #dee2e6;
        }

        h2 {
            color: #343a40;
            margin-bottom: 30px;
            text-align: center;
        }
    </style>
</head>
<body>

    <div class="container">
        <h2>@ViewBag.Title</h2>

        <table class="table table-bordered table-striped">
            <thead>
                <tr>
                    <th>User ID</th>
                    <th>Name</th>
                    <th>Email</th>
                    <th>CNIC</th>
                    <th>Date of Birth</th>
                    <th>Role</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var user in Model)
                    {
                        <tr>
                            <td>@user.UserId</td>
                            <td>@user.Name</td>
                            <td>@user.Email</td>
                            <td>@user.CITNo</td>
                            <td>@user.DOB.ToShortDateString()</td>
                            <td>@user.Role</td>
                            <td>
                                <a href="@Url.Action("UpdateUser", "User", new { id = user.UserId })" class="btn btn-warning btn-sm">Edit</a>
                                <a href="@Url.Action("DeleteUser", "User", new { id = user.UserId })" class="btn btn-danger btn-sm" onclick="return confirm('Are you sure you want to delete this user?');">Delete</a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="7" class="text-center">No users found.</td>
                    </tr>
                }
            </tbody>
        </table>

        <a href="@Url.Action("InsertUser", "User")" class="btn btn-custom">Add New User</a>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
