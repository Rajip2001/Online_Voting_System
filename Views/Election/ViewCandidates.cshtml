@{
    Layout = null;
    ViewData["Title"] = "Candidates";
    var candidates = (List<OnlineVoting.Models.Candidate>)Model;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] - Online Election System</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha3/dist/css/bootstrap.min.css">

    <style>
        body {
            background: linear-gradient(to bottom right, #6a11cb, #2575fc);
            min-height: 100vh;
            padding: 20px;
        }

        .card-container {
            background: #ffffff;
            border-radius: 15px;
            padding: 30px;
            max-width: 1000px;
            margin: auto;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
        }

        .candidate-card {
            border: 1px solid #ddd;
            border-radius: 10px;
            padding: 15px;
            margin-bottom: 20px;
        }

        .candidate-img {
            width: 100px;
            height: 100px;
            object-fit: cover;
            border-radius: 50%;
        }

        .logo-img {
            width: 80px;
            height: 80px;
            object-fit: contain;
        }
    </style>
</head>

<body>

<div class="card-container">
     <h3 class="text-center fw-bolder" style="color:dimgrey;">
        @ViewData["Title"]
    </h3>

    @if (candidates != null && candidates.Count > 0)
    {
        @foreach (var candidate in candidates)
        {
            <div class="candidate-card">
                <div class="row">
                    <div class="col-md-3 text-center">
                        <p><strong>Profile</strong></p>
                        <img src="@candidate.ProfilePicture" class="candidate-img" />
                    </div>

                    <div class="col-md-3 text-center">
                        <p><strong>Party Logo</strong></p>
                        <img src="@candidate.Logo" class="logo-img" />
                    </div>

                    <div class="col-md-6">
                        <p><strong>Name:</strong> @candidate.Name</p>
                        <p><strong>Age:</strong> @candidate.Age</p>
                        <p><strong>CIT No:</strong> @candidate.CITNo</p>
                        <p><strong>Education:</strong> @candidate.Education</p>
                        <p><strong>Party:</strong> @candidate.Party</p>
                        <p><strong>Votes:</strong> @candidate.VoteCount</p>
                        <p><strong>Manifesto:</strong> @candidate.Manifesto</p>
                    </div>
                </div>
            </div>
        }
    }
    else
    {
        <p class="text-center">No candidates found.</p>
    }

    <div class="text-center mt-3">
        <a asp-controller="Admin" asp-action="Index" class="btn btn-primary">
            ← Back to Dashboard
        </a>
    </div>
</div>

</body>
</html>