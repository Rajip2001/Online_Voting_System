@{
    Layout = null;
    ViewData["Title"] = "Candidates";
    var candidates = (List<Candidate>)Model;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] - Online Election System</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha3/dist/css/bootstrap.min.css">

    <style>
        body {
            background: linear-gradient(to bottom right, #6a11cb, #2575fc);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .card-container {
            background: #ffffff;
            border-radius: 15px;
            padding: 30px;
            width: 800px;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
        }

        h3 {
            color: dimgrey;
        }

        .table th {
            background: linear-gradient(to right, #6a11cb, #2575fc);
            color: white;
            text-align: center;
        }

        .table td {
            text-align: center;
        }

        .table-hover tbody tr:hover {
            background-color: #f1f1f1;
        }

        .btn-custom {
            background: linear-gradient(to right, #6a11cb, #2575fc);
            color: #fff;
            border: none;
            font-weight: bold;
            transition: all 0.3s ease-in-out;
        }

        .btn-custom:hover {
            background: linear-gradient(to right, #2575fc, #6a11cb);
            transform: scale(1.05);
        }
    </style>
</head>

<body>

    <div class="card-container">
        <h3 class="text-center fw-bolder">@ViewData["Title"]</h3>

        <div class="table-responsive mt-4">
            <table class="table table-bordered table-hover">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Age</th>
                        <th>Party</th>
                        <th>Votes</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var candidate in candidates)
                    {
                        <tr>
                            <td>@candidate.Name</td>
                            <td>@candidate.Age</td>
                            <td>@candidate.Party</td>
                            <td>@candidate.VoteCount</td>
                        </tr>
                    }
                </tbody>
            </table>
            <!-- Back Button -->
        <div class="text-center mt-3">
            <a asp-controller="Admin" asp-action="Index" class="btn btn-custom">
                ← Back to Dashboard
            </a>
        </div>
        </div>

        
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha3/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>