@{
    Layout = null;
    ViewData["Title"] = "Candidates";
    var candidates = (List<Candidate>)Model;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] - Online Election System</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha3/dist/css/bootstrap.min.css">
    <style>
        body {
            background: linear-gradient(to bottom right, #6a11cb, #2575fc); /* Gradient background */
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
        }

        .table-container {
            background: #ffffff;
            border-radius: 15px;
            padding: 20px;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1); /* Subtle shadow */
            width: 80%;
            max-width: 800px;
            margin-bottom: 20px;
        }

        h1 {
            color: #ffffff;
            margin-bottom: 20px;
            text-align: center;
        }

        table {
            width: 100%;
            border-collapse: collapse;
        }

        th, td {
            padding: 10px;
            text-align: center;
        }

        th {
            background: #2575fc;
            color: #ffffff;
        }

        tr:nth-child(even) {
            background: #f2f2f2;
        }

        tr:hover {
            background: #e0e0e0;
        }

        a {
            text-decoration: none;
            color: #2575fc;
            font-weight: bold;
        }

            a:hover {
                text-decoration: underline;
            }

        .btn-custom {
            background: linear-gradient(to right, #6a11cb, #2575fc);
            color: #fff;
            border: none;
            font-weight: bold;
            transition: all 0.3s ease-in-out;
            padding: 10px 20px;
            border-radius: 5px;
            display: inline-block;
            margin-top: 10px;
        }

            .btn-custom:hover {
                background: linear-gradient(to right, #2575fc, #6a11cb);
                transform: scale(1.05); /* Subtle hover animation */
            }
    </style>
</head>
<body>
    <h1 class="fw-bolder">@ViewData["Title"]</h1>
    <div class="table-container">
        <table class="table table-bordered table-striped">
            <thead>
                <tr>
                    <th style="color:dimgray">Name</th>
                    <th style="color:dimgray">Age</th>
                    <th style="color:dimgray">Party</th>
                    <th style="color:dimgray">Votes</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var candidate in candidates)
                {
                    <tr>
                        <td>@candidate.Name</td>
                        <td>@candidate.Age</td>
                        <td>@candidate.Party</td>
                        <td>@candidate.VoteCount</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    <a href="@Url.Action("GetAllElections", "Election")" class="btn-custom">Back to All Elections</a>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
