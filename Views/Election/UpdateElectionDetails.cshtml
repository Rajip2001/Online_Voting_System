@{
    Layout = null;
    ViewData["Title"] = "Update Election Details";
    var election = (Election)Model;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] - Online Election System</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha3/dist/css/bootstrap.min.css">
    <style>
        body {
            background: linear-gradient(to bottom right, #6a11cb, #2575fc); /* Gradient background */
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .card {
            background: #ffffff; /* Clean white card */
            border: none;
            width: 400px;
            border-radius: 15px;
            padding: 30px;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1); /* Subtle shadow */
        }

        .btn-custom {
            background: linear-gradient(to right, #6a11cb, #2575fc); /* Gradient button */
            color: #fff;
            border: none;
            font-weight: bold;
            transition: all 0.3s ease-in-out;
        }

            .btn-custom:hover {
                background: linear-gradient(to right, #2575fc, #6a11cb);
                transform: scale(1.05); /* Subtle hover animation */
            }

        h3 {
            color: dimgray;
            margin-bottom: 20px;
            text-align: center;
            font-weight: bold;
        }

        a {
            text-decoration: none;
            color: #2575fc;
        }

            a:hover {
                text-decoration: underline;
            }

        label {
            color: dimgray;
            font-weight: bold;
        }

        small {
            text-align: center;
            display: block;
            margin-top: 10px;
        }
    </style>
</head>
<body>
    <div class="card">
        <h3>@ViewData["Title"]</h3>
        <form asp-action="UpdateElectionDetails" method="post">
            <input type="hidden" id="ElectionId" name="ElectionId" value="@election.ElectionId" />
            <div class="mb-3">
                <label for="Name" class="form-label">Election Name*</label>
                <input type="text" class="form-control" id="Name" name="Name" value="@election.Name" placeholder="Enter election name" required />
            </div>
            <div class="mb-3">
                <label for="StartDate" class="form-label">Start Date*</label>
                <input type="date" class="form-control" id="StartDate" name="StartDate" value="@election.StartDate.ToString("yyyy-MM-dd")" required />
            </div>
            <div class="mb-3">
                <label for="EndDate" class="form-label">End Date*</label>
                <input type="date" class="form-control" id="EndDate" name="EndDate" value="@election.EndDate.ToString("yyyy-MM-dd")" required />
            </div>
            <div class="d-grid">
                <button type="submit" class="btn btn-custom">Update</button>
            </div>
        </form>
        <small>
            <a href="@Url.Action("ElectionDetails", "Election", new { electionId = election.ElectionId })">Back to Election Details</a>
        </small>
        <small>
            <a href="@Url.Action("GetAllElections", "Election")">Back to All Elections</a>
        </small>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
