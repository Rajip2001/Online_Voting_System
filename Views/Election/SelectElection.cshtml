@model IList<OnlineVoting.Models.Election>

@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <title>Select Election</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">

    <style>
        body {
            background: linear-gradient(to bottom right, #6a11cb, #2575fc);
            height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
        }

        .card {
            width: 500px;
            padding: 30px;
            border-radius: 15px;
            background: white;
            box-shadow: 0 4px 20px rgba(0,0,0,0.1);
        }

        .btn-custom {
            background: linear-gradient(to right, #6a11cb, #2575fc);
            color: white;
            border: none;
            margin-top: 10px;
        }

        .btn-custom:hover {
            transform: scale(1.03);
        }
    </style>
</head>

<body>

<div class="card">
    <h3 class="text-center fw-bold">Select Election</h3>

    @foreach (var election in Model)
    {
        <div class="d-grid">
            <a asp-controller="Vote"
            asp-action="CastVoteForm"
            asp-route-electionId="@election.ElectionId"
            class="btn btn-custom">
                @election.Name (@election.StartDate.ToShortDateString())
            </a>
        </div>
    }
</div>

</body>
</html>